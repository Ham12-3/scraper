# ─────────────────────────────────────────────────────────────────────────────
# Scraper System — environment variables
# Copy this file to .env and fill in the values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Anthropic API key — used by Module 2's LLM extractor fallback.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── OPTIONAL OVERRIDES ────────────────────────────────────────────────────────

# Set to false to have the scraper-worker actually open a real Chromium browser
# and scrape URLs. Default true uses canned HTML (no internet access needed).
SCRAPER_MOCK_MODE=true
